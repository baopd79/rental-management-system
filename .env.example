# ============================================
# RMS Development Environment Variables
# Copy this file to .env and fill in real values
# ============================================

# PostgreSQL (for Docker Compose)
POSTGRES_USER=rms
POSTGRES_PASSWORD=changeme_in_env
POSTGRES_DB=rms_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5433


# APPLICATION
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=false
# JWT
DATABASE_URL=postgresql+psycopg://rms_user:changeme@localhost:5433/rms_dev
JWT_SECRET_KEY=changeme_in_env
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:5173","https://staging.rms-app.vn"]

# LOGGING
LOG_LEVEL=info