# ============================================
# RMS Development Environment Variables
# Copy this file to .env and fill in real values
# ============================================

# PostgreSQL (for Docker Compose + app)
POSTGRES_USER=rms
POSTGRES_PASSWORD=changeme_in_env
POSTGRES_DB=rms_dev
POSTGRES_TEST_DB=rms_test
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# App
APP_VERSION=0.1.0
APP_ENV=development
LOG_LEVEL=INFO

# Auth (Stage 1.2+)
SECRET_KEY=changeme-replace-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60